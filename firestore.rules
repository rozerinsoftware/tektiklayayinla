rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    /** Firebase Auth JWT — uygulamadaki giriş kontrolü ile aynı */
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /** İlan / profil güncelleme: onaylı e-posta veya admin */
    function yazmaIzni() {
      return isSignedIn() && (isEmailVerified() || isAdmin());
    }

    function kategoriKonumZorunlu(kok) {
      return kok == 'emlak'
        || kok == 'vasita'
        || kok == 'ikinci-el'
        || kok == 'is-makineleri';
    }

    function konumGecerli(konum) {
      return konum is map
        && konum.keys().hasAll(['latitude', 'longitude'])
        && konum.latitude is number
        && konum.longitude is number
        && konum.latitude >= -90
        && konum.latitude <= 90
        && konum.longitude >= -180
        && konum.longitude <= 180;
    }

    /** Emlak / vasıta / ikinci el / iş makineleri → geçerli GPS konumu zorunlu */
    function ilanKonumSartlari() {
      let kok = request.resource.data.get('kategoriKok', '');
      return !kategoriKonumZorunlu(kok) || konumGecerli(request.resource.data.konum);
    }

    function ilanTemelAlanlarTamam() {
      return request.resource.data.keys().hasAll(['ownerId', 'baslik', 'aciklama', 'fiyat'])
        && request.resource.data.baslik is string
        && request.resource.data.baslik.size() > 0
        && request.resource.data.aciklama is string
        && request.resource.data.aciklama.size() > 0;
    }

    function konusmaUyesi(konusmaId) {
      return yazmaIzni()
        && request.auth.uid in get(/databases/$(database)/documents/konusmalar/$(konusmaId)).data.katilimcilar;
    }

    /** Gösterim / mesaj / favori sayacı — yalnızca +1, diğer alanlar değişmez */
    function ilanIstatistikArtisi(alan) {
      return isSignedIn()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.baslik == resource.data.baslik
        && request.resource.data.aciklama == resource.data.aciklama
        && request.resource.data.fiyat == resource.data.fiyat
        && request.resource.data.get(alan, 0) == resource.data.get(alan, 0) + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([alan, 'updatedAt']);
    }

    match /users/{userId} {
      allow read: if yazmaIzni() || isAdmin() || (isSignedIn() && request.auth.uid == userId);

      // Kayıt: profil ilk kez e-posta doğrulanmadan oluşturulabilir (sonra çıkış)
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'user';

      allow update: if yazmaIzni()
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role;

      allow delete: if false;
    }

    match /ilanlar/{ilanId} {
      allow read: if true;

      allow create: if yazmaIzni()
        && request.resource.data.ownerId == request.auth.uid
        && ilanTemelAlanlarTamam()
        && ilanKonumSartlari();

      allow update: if (
        yazmaIzni()
        && request.resource.data.ownerId == resource.data.ownerId
        && ilanKonumSartlari()
        && (
          resource.data.ownerId == request.auth.uid
          || isAdmin()
        )
      ) || ilanIstatistikArtisi('goruntulenme')
        || ilanIstatistikArtisi('mesajSayisi')
        || ilanIstatistikArtisi('favoriSayisi');

      allow delete: if yazmaIzni()
        && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /konusmalar/{konusmaId} {
      allow read: if yazmaIzni()
        && request.auth.uid in resource.data.katilimcilar;

      allow create: if yazmaIzni()
        && request.auth.uid in request.resource.data.katilimcilar
        && request.resource.data.katilimcilar.size() == 2
        && request.resource.data.keys().hasAll(['ilanId', 'katilimcilar', 'ownerId']);

      allow update: if konusmaUyesi(konusmaId);

      allow delete: if false;

      match /mesajlar/{mesajId} {
        allow read: if konusmaUyesi(konusmaId);

        allow create: if konusmaUyesi(konusmaId)
          && request.resource.data.gonderenId == request.auth.uid
          && request.resource.data.metin is string
          && request.resource.data.metin.size() > 0
          && request.resource.data.metin.size() <= 2000;

        allow update, delete: if false;
      }
    }
  }
}
